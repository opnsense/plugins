<model>
    <mount>//OPNsense/Nut</mount>
    <description>Network UPS Tools</description>
    <version>1.1.0</version>
    <items>
        <general>
            <enable type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </enable>
            <mode type="OptionField">
                <Default>standalone</Default>
                <Required>Y</Required>
                <OptionValues>
                    <standalone>standalone</standalone>
                    <netclient>netclient</netclient>
                </OptionValues>
            </mode>
            <listen type="CSVListField">
                <Default>127.0.0.1,::1</Default>
                <Required>Y</Required>
            </listen>
        </general>
        <account>
            <admin_password type="TextField">
                <Required>Y</Required>
                <Default>Password</Default>
            </admin_password>
            <mon_password type="TextField">
                <Required>Y</Required>
                <Default>Password</Default>
            </mon_password>
        </account>
        <upses>
            <ups type="ArrayField">
                <enabled type="BooleanField">
                    <Default>1</Default>
                    <Required>Y</Required>
                </enabled>
                <name type="TextField">
                    <Required>Y</Required>
                    <Mask>/^([0-9a-zA-Z._\-]){1,128}$/u</Mask>
                    <ValidationMessage>The name should only contain alphanumeric characters, dashes, underscores or a dot.</ValidationMessage>
                    <Constraints>
                        <check001>
                            <ValidationMessage>A UPS with this name already exists.</ValidationMessage>
                            <type>UniqueConstraint</type>
                        </check001>
                    </Constraints>
                </name>
                <driver type="OptionField">
                    <Default>usbhid-ups</Default>
                    <Required>Y</Required>
                    <OptionValues>
                        <usbhid-ups>usbhid-ups (USB HID devices)</usbhid-ups>
                        <apcsmart>apcsmart (APC smart protocol, serial)</apcsmart>
                        <apcupsd-ups>apcupsd-ups (apcupsd network server)</apcupsd-ups>
                        <bcmxcp_usb>bcmxcp_usb (PowerWare BCMXCP, USB)</bcmxcp_usb>
                        <blazer_usb>blazer_usb (Megatec/Q1 protocol, USB)</blazer_usb>
                        <blazer_ser>blazer_ser (Megatec/Q1 protocol, serial)</blazer_ser>
                        <nutdrv_qx>nutdrv_qx (Megatec/Voltronic Q* protocol)</nutdrv_qx>
                        <riello_usb>riello_usb (Riello, USB)</riello_usb>
                        <snmp-ups>snmp-ups (SNMP)</snmp-ups>
                    </OptionValues>
                </driver>
                <powervalue type="IntegerField">
                    <Default>1</Default>
                    <Required>Y</Required>
                    <MinimumValue>0</MinimumValue>
                    <MaximumValue>16</MaximumValue>
                    <ValidationMessage>The power value needs to be an integer value between 0 and 16.</ValidationMessage>
                </powervalue>
                <args type="CSVListField">
                    <Default>port=auto</Default>
                    <Required>Y</Required>
                    <Mask>/^[0-9a-zA-Z._\-]+(=[^,]*)?$/u</Mask>
                    <MaskPerItem>Y</MaskPerItem>
                    <ValidationMessage>Arguments should be a list of key=value pairs or driver flags.</ValidationMessage>
                </args>
            </ups>
        </upses>
        <netclient>
            <enable type="BooleanField">
                <Required>Y</Required>
                <Default>0</Default>
            </enable>
            <name type="TextField">
                <Default>UPSName</Default>
                <Required>Y</Required>
                <Mask>/^([0-9a-zA-Z._\-]){1,128}$/u</Mask>
                <ValidationMessage>The name should only contain alphanumeric characters, dashes, underscores or a dot.</ValidationMessage>
            </name>
            <address type="HostnameField"/>
            <port type="PortField">
                <Default>3493</Default>
                <Required>N</Required>
            </port>
            <user type="TextField">
                <Required>N</Required>
            </user>
            <password type="TextField">
                <Required>N</Required>
            </password>
        </netclient>
    </items>
</model>

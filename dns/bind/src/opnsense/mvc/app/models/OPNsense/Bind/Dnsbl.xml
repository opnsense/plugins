<model>
    <mount>//OPNsense/bind/dnsbl</mount>
    <description>DNSBL configuration</description>
    <version>1.0.7</version>
    <items>
        <enabled type="BooleanField">
            <Default>0</Default>
            <Required>Y</Required>
        </enabled>
        <memoryguard type="IntegerField">
            <Default>300</Default>
            <Required>Y</Required>
            <MinimumValue>0</MinimumValue>
            <MaximumValue>32768</MaximumValue>
            <ValidationMessage>Choose a value between 0 and 32768.</ValidationMessage>
        </memoryguard>
        <type type="OptionField">
            <Required>N</Required>
            <Multiple>Y</Multiple>
        </type>
        <whitelists type="CSVListField">
            <Required>N</Required>
        </whitelists>
        <forcesafegoogle type="BooleanField">
            <Default>0</Default>
            <Required>Y</Required>
        </forcesafegoogle>
        <forcesafeduckduckgo type="BooleanField">
            <Default>0</Default>
            <Required>Y</Required>
        </forcesafeduckduckgo>
        <forcesafeyoutube type="BooleanField">
            <Default>0</Default>
            <Required>Y</Required>
        </forcesafeyoutube>
        <forcestrictbing type="BooleanField">
            <Default>0</Default>
            <Required>Y</Required>
        </forcestrictbing>
    </items>
</model>
